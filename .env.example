# Frontend (Vite) environment template. Copy to ".env.local" and fill in.
# Only VITE_-prefixed variables are exposed to the browser — never put
# secrets (service-role key, DB password) here.

# ── Supabase (browser-safe values only) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: API base URL. Leave empty to use the Vite "/api" dev proxy.
VITE_API_URL=
