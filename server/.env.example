# Copy this file to ".env" and fill in your values. ".env" is git-ignored.

# Port the API listens on (the Vite dev proxy expects 3001).
PORT=3001

# ── Supabase ──────────────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SECRET — server only, bypasses Row Level Security. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=

# ── Email (Resend) — optional ─────────────────────────────────
# Create a free key at https://resend.com
RESEND_API_KEY=
# For real delivery, verify a domain and use that address; the sandbox sender
# below only delivers to your own Resend account email.
FROM_EMAIL="Pierre-Blaise Family <onboarding@resend.dev>"
